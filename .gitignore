# Ignore everything by default
*

# Except docs directory and gitignore itself
!docs/
!docs/**
!.gitignore

# Track the cross-platform build foundation (real source).
# No hosted CI by design (cloud-exit / minimize vendor lock-in) — the build gate
# is local `make verify`; nothing GitHub-specific is tracked.
!ranserver-linux/
!ranserver-linux/**

# ...but never build artifacts
ranserver-linux/build/
ranserver-linux/build-host/
